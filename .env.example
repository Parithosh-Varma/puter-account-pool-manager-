# Server Configuration
PORT=3000
NODE_ENV=development

# Puter API Configuration
PUTER_API_BASE_URL=https://api.puter.com

# Account Pool Configuration
# Define accounts as a JSON array of { id, name, token, dailyCreditLimit }
# ACCOUNTS=[{"id":"acc1","name":"Account 1","token":"your-puter-auth-token","dailyCreditLimit":100}]

# Alternatively, load accounts from individual environment variables:
# ACCOUNT_1_ID=acc1
# ACCOUNT_1_NAME=Account 1
# ACCOUNT_1_TOKEN=your-token-here
# ACCOUNT_1_DAILY_LIMIT=100

# Scheduling Strategy: round-robin | least-used
SCHEDULER_STRATEGY=round-robin

# Health Check Configuration
HEALTH_CHECK_INTERVAL_MS=60000
HEALTH_CHECK_TIMEOUT_MS=10000

# Credit Tracking Configuration
CREDIT_RESET_INTERVAL_MS=86400000
DEFAULT_DAILY_CREDIT_LIMIT=100

# Request Queue Configuration
MAX_QUEUE_SIZE=1000
REQUEST_TIMEOUT_MS=30000
MAX_RETRIES=3

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/account-pool.log

# Dashboard Configuration
DASHBOARD_PORT=5173

# Database (Supabase) — stores AI request/response history
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Security
API_KEY=change-me-to-a-secure-random-string

# Google OAuth (for dashboard sign-in)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
